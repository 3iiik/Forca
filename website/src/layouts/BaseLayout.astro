---
const { title, description, structuredData } = Astro.props;
import '../styles/globals.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={import.meta.env.BASE_URL + 'icon.png'} />
    <meta name="theme-color" content="#09090b" />

    <!-- SEO -->
    <title>{title} · Forca</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="focus app, website blocker, productivity app, distraction blocker, focus mode, deep work, study app" />
    <meta name="author" content="3iiik" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Forca" />
    <meta property="og:title" content={`${title} · Forca`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content="https://3iiik.github.io/Forca/screenshots/app-dashboard.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} · Forca`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://3iiik.github.io/Forca/screenshots/app-dashboard.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500&family=Josefin+Sans:wght@600;700&display=swap" rel="stylesheet" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>

    <style>
      :root {
        --font-heading: 'Josefin Sans', sans-serif;
        --font-body: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        --bg: #09090b;
        --bg-card: #18181b;
        --bg-hover: #27272a;
        --border: #27272a;
        --text: #f4f4f5;
        --text-muted: #a1a1aa;
        --text-dim: #8a8a94;
        --primary: #064e3b;
        --primary-hover: #065f46;
        --primary-text: #d1fae5;
        --accent: #1D9E75;
        --accent-hover: #34d399;
        --success: #22c55e;
        --radius: 12px;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      h1, h2, h3, h4, h5, h6, .font-heading {
        font-family: var(--font-heading);
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { color: var(--accent-hover); }
      img { max-width: 100%; height: auto; }

      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      .container { max-width: 1400px; margin: 0 auto; padding: 0 24px; }
      .container-narrow { max-width: 720px; margin: 0 auto; padding: 0 24px; }

      nav {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 24px; max-width: 1400px; margin: 0 auto;
        border-bottom: 1px solid var(--border);
      }
      .logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 18px;
        font-weight: 700;
        font-family: var(--font-heading);
        color: var(--text);
        letter-spacing: -0.3px;
      }
      nav .logo img {
        width: 48px;
        height: 48px;
        flex-shrink: 0;
      }
      nav .links { display: flex; gap: 12px; align-items: center; }
      @media (min-width: 640px) { nav .links { gap: 24px; } }
      nav .links a { color: var(--text-muted); font-size: 14px; font-weight: 500; transition: color .2s; }
      nav .links a:hover, nav .links a.active { color: var(--text); }
      nav .links a.nav-cta {
        background: var(--accent); color: #fff; padding: 8px 16px; border-radius: 8px;
        font-weight: 600; font-size: 13px;
      }
      nav .links a.nav-cta:hover { background: var(--accent-hover); color: #fff; }
      nav .links a.nav-icon {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px; border-radius: 8px;
        border: 1px solid transparent;
        color: var(--text-muted); transition: all .2s;
      }
      nav .links a.nav-icon:hover { color: var(--accent); background: rgba(29,158,117,0.1); border-color: rgba(29,158,117,0.2); }
      nav .links a.nav-icon:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

      .hamburger { display: none; background: none; border: none; cursor: pointer; padding: 8px; border-radius: 8px; flex-direction: column; gap: 5px; }
      .hamburger span { display: block; width: 22px; height: 2px; background: var(--text); border-radius: 2px; transition: all .3s; }
      .hamburger:hover { background: rgba(29,158,117,0.1); }
      .hamburger:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
      .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .hamburger.open span:nth-child(2) { opacity: 0; }
      .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      .drawer-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 99; opacity: 0; pointer-events: none; transition: opacity .3s; }
      .drawer-overlay.open { opacity: 1; pointer-events: auto; }

      .drawer { position: fixed; top: 0; right: 0; bottom: 0; width: 300px; max-width: 85vw; background: var(--bg); border-left: 1px solid var(--border); z-index: 100; transform: translateX(100%); transition: transform .3s ease; display: flex; flex-direction: column; overflow-y: auto; }
      .drawer.open { transform: translateX(0); }
      .drawer-header { display: flex; align-items: center; justify-content: flex-end; padding: 16px 20px; border-bottom: 1px solid var(--border); }
      .drawer-body { padding: 16px 12px; flex: 1; }
      .drawer-body a { display: flex; align-items: center; padding: 14px 16px; font-size: 15px; font-weight: 500; color: var(--text-muted); border-radius: 10px; transition: all .2s; min-height: 44px; }
      .drawer-body a:hover { color: var(--text); background: rgba(29,158,117,0.08); }
      .drawer-body hr { border: none; border-top: 1px solid var(--border); margin: 8px 12px; }
      .drawer-body .drawer-icon-link { gap: 10px; }
      .drawer-body .drawer-icon-link svg { width: 18px; height: 18px; }

      h2 { font-size: 32px; font-weight: 700; letter-spacing: -0.5px; line-height: 1.2; margin-bottom: 16px; }

      footer {
        border-top: 1px solid var(--border);
        padding: 48px 24px 32px;
        font-size: 13px;
      }
      footer .footer-grid {
        max-width: 1400px; margin: 0 auto;
        display: grid; grid-template-columns: 1fr;
        gap: 32px;
      }
      @media (min-width: 640px) {
        footer .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; }
      }
      footer .footer-brand p { color: var(--text-dim); margin-top: 12px; line-height: 1.7; max-width: 320px; }
      footer h4 { color: var(--text); font-size: 13px; font-weight: 600; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px; }
      footer .footer-links { display: flex; flex-direction: column; gap: 10px; }
      footer .footer-links a { color: var(--text-muted); font-size: 13px; transition: color .2s; }
      footer .footer-links a:hover { color: var(--text); }
      footer .footer-bottom {
        max-width: 1400px; margin: 32px auto 0; padding-top: 24px;
        border-top: 1px solid var(--border);
        display: flex; flex-direction: column; gap: 8px; align-items: center;
        color: var(--text-dim); font-size: 12px;
      }
      @media (min-width: 640px) {
        footer .footer-bottom { flex-direction: row; justify-content: space-between; }
      }
      footer .footer-bottom a { color: var(--text-muted); }
      footer .footer-bottom a:hover { color: var(--text); }

      .page-bg {
        position: relative;
        background: linear-gradient(180deg, rgba(6,78,59,0.18) 0%, rgba(29,158,117,0.06) 120px, transparent 450px);
        min-height: 100vh;
        user-select: none;
      }
      .selectable, .selectable * { user-select: text; }
      code, pre, input, textarea { user-select: text; }

      .section { padding: 64px 0; }
      .section-alt { background: var(--bg-card); }

      .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
      .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; }
      .grid-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 20px; }



      .badge { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; }
      .badge-green { background: #14532d; color: #86efac; }
      .badge-green { background: rgba(29, 158, 117, 0.15); color: #34d399; }
      .badge-yellow { background: #422006; color: #fde68a; }

      .page-header { padding: 64px 0 32px; }
      .page-header h1 { font-size: 36px; }
      .page-header p { color: var(--text-muted); font-size: 16px; }

      pre, code { font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', Consolas, monospace; }
      code { background: var(--bg-hover); padding: 2px 6px; border-radius: 4px; font-size: 13px; }
      pre { background: #0f0f11; border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; overflow-x: auto; margin: 12px 0; }
      pre code { background: none; padding: 0; }

      .page-content { padding-bottom: 80px; }
      .page-content h2 { font-size: 24px; margin-top: 40px; margin-bottom: 12px; }
      .page-content h3 { font-size: 18px; margin-top: 28px; margin-bottom: 8px; }
      .page-content p, .page-content li { font-size: 15px; color: var(--text-muted); line-height: 1.7; }
      .page-content ul, .page-content ol { padding-left: 20px; margin: 12px 0; }
      .page-content li { margin-bottom: 6px; }

      @media (max-width: 768px) {
        h2 { font-size: 24px; }
        .section { padding: 40px 0; }
        .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; }
        footer .footer-grid { grid-template-columns: 1fr; gap: 32px; }
        footer .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
      }

      @media (max-width: 767px) {
        nav .links { display: none; }
        .hamburger { display: flex; }
        nav .logo img { width: 44px; height: 44px; }
        nav .logo { font-size: 20px; gap: 12px; }
        nav { padding: 12px 16px; }
      }
    </style>
  </head>
  <body>
    <div class="page-bg">
    <nav>
      <a href={import.meta.env.BASE_URL} class="logo">
            <img src={import.meta.env.BASE_URL + 'branding/forca-mark.svg'} alt="Forca" width="52" height="52" />
      </a>
      <div class="links">
        <a href={import.meta.env.BASE_URL + 'features/'}>Features</a>
