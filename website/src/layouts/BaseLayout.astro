---
const { title, description, structuredData } = Astro.props;
import '../styles/globals.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/Forca/icon.png" />
    <meta name="theme-color" content="#09090b" />

    <!-- SEO -->
    <title>{title} · Forca</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="focus app, website blocker, productivity app, distraction blocker, focus mode, deep work, study app" />
    <meta name="author" content="3iiik" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Forca" />
    <meta property="og:title" content={`${title} · Forca`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content="https://3iiik.github.io/Forca/screenshots/app-dashboard.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} · Forca`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://3iiik.github.io/Forca/screenshots/app-dashboard.png" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>

    <style>
      :root {
        --bg: #09090b;
        --bg-card: #18181b;
        --bg-hover: #27272a;
        --border: #27272a;
        --text: #f4f4f5;
        --text-muted: #a1a1aa;
        --text-dim: #8a8a94;
        --primary: #4c1d95;
        --primary-hover: #5b21b6;
        --primary-text: #ede9fe;
        --accent: #8b5cf6;
        --accent-hover: #a78bfa;
        --success: #22c55e;
        --radius: 12px;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { color: var(--accent-hover); }
      img { max-width: 100%; height: auto; }

      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      .container { max-width: 1400px; margin: 0 auto; padding: 0 24px; }
      .container-narrow { max-width: 720px; margin: 0 auto; padding: 0 24px; }

      nav {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 24px; max-width: 1400px; margin: 0 auto;
        border-bottom: 1px solid var(--border);
      }
      nav .logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 18px;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.3px;
      }
      nav .logo img {
        width: 20px;
        height: 20px;
        border-radius: 5px;
        flex-shrink: 0;
      }
      nav .links { display: flex; gap: 12px; align-items: center; }
      @media (min-width: 640px) { nav .links { gap: 24px; } }
      nav .links a { color: var(--text-muted); font-size: 14px; font-weight: 500; transition: color .2s; }
      nav .links a:hover, nav .links a.active { color: var(--text); }
      nav .links a.nav-cta {
        background: var(--accent); color: #fff; padding: 8px 16px; border-radius: 8px;
        font-weight: 600; font-size: 13px;
      }
      nav .links a.nav-cta:hover { background: var(--accent-hover); color: #fff; }

      h2 { font-size: 32px; font-weight: 700; letter-spacing: -0.5px; line-height: 1.2; margin-bottom: 16px; }

      footer {
        border-top: 1px solid var(--border);
        padding: 48px 24px 32px;
        font-size: 13px;
      }
      footer .footer-grid {
        max-width: 1400px; margin: 0 auto;
        display: grid; grid-template-columns: 1fr;
        gap: 32px;
      }
      @media (min-width: 640px) {
        footer .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; }
      }
      footer .footer-brand p { color: var(--text-dim); margin-top: 12px; line-height: 1.7; max-width: 320px; }
      footer h4 { color: var(--text); font-size: 13px; font-weight: 600; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px; }
      footer .footer-links { display: flex; flex-direction: column; gap: 10px; }
      footer .footer-links a { color: var(--text-muted); font-size: 13px; transition: color .2s; }
      footer .footer-links a:hover { color: var(--text); }
      footer .footer-bottom {
        max-width: 1400px; margin: 32px auto 0; padding-top: 24px;
        border-top: 1px solid var(--border);
        display: flex; flex-direction: column; gap: 8px; align-items: center;
        color: var(--text-dim); font-size: 12px;
      }
      @media (min-width: 640px) {
        footer .footer-bottom { flex-direction: row; justify-content: space-between; }
      }
      footer .footer-bottom a { color: var(--text-muted); }
      footer .footer-bottom a:hover { color: var(--text); }

      .section { padding: 64px 0; }
      .section-alt { background: var(--bg-card); }

      .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
      .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; }
      .grid-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 20px; }

      .faq-wrapper {
        border: 1px solid var(--border);
        border-radius: 16px;
        background: var(--bg-card);
        overflow: hidden;
      }
      .faq-item {
        border-bottom: 1px dashed rgba(255,255,255,0.08);
      }
      .faq-item:last-child { border-bottom: none; }
      .faq-q {
        width: 100%; display: flex; justify-content: space-between; align-items: center;
        gap: 12px; padding: 20px 24px; font-weight: 500; font-size: 15px; cursor: pointer;
        color: var(--text); background: none; border: none; text-align: left;
        font-family: inherit; transition: color .2s;
      }
      .faq-q span { min-width: 0; flex: 1; }
      .faq-q:hover { color: var(--accent); }
      .faq-q:hover .faq-icon { color: var(--accent); }
      .faq-icon { transition: transform .3s; flex-shrink: 0; color: var(--text-muted); width: 20px; height: 20px; }
      .faq-q[aria-expanded="true"] .faq-icon { transform: rotate(45deg); color: var(--accent); }
      .faq-a {
        overflow: hidden; max-height: 0; transition: max-height .35s ease;
        font-size: 14px; color: var(--text-muted); line-height: 1.7;
      }
      .faq-a.open { max-height: 400px; }
      .faq-a-inner { padding: 0 24px 24px; }

      .badge { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; }
      .badge-green { background: #14532d; color: #86efac; }
      .badge-purple { background: rgba(139, 92, 246, 0.15); color: #a78bfa; }
      .badge-yellow { background: #422006; color: #fde68a; }

      .page-header { padding: 64px 0 32px; }
      .page-header h1 { font-size: 36px; }
      .page-header p { color: var(--text-muted); font-size: 16px; }

      pre, code { font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', Consolas, monospace; }
      code { background: var(--bg-hover); padding: 2px 6px; border-radius: 4px; font-size: 13px; }
      pre { background: #0f0f11; border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; overflow-x: auto; margin: 12px 0; }
      pre code { background: none; padding: 0; }

      .page-content { padding-bottom: 80px; }
      .page-content h2 { font-size: 24px; margin-top: 40px; margin-bottom: 12px; }
      .page-content h3 { font-size: 18px; margin-top: 28px; margin-bottom: 8px; }
      .page-content p, .page-content li { font-size: 15px; color: var(--text-muted); line-height: 1.7; }
      .page-content ul, .page-content ol { padding-left: 20px; margin: 12px 0; }
      .page-content li { margin-bottom: 6px; }

      @media (max-width: 768px) {
        h2 { font-size: 24px; }
        .section { padding: 40px 0; }
        .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; }
        nav .links { gap: 12px; }
        nav .links a { font-size: 13px; }
        footer .footer-grid { grid-template-columns: 1fr; gap: 32px; }
        footer .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
      }

      @media (max-width: 480px) {
        .container, .container-narrow { padding: 0 16px; }
        nav { padding: 12px 16px; }
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/Forca/" class="logo">
        <img src="/Forca/icon.png" alt="Forca" width="20" height="20" />
        Forca
      </a>
      <div class="links">
        <a href="/Forca/">Home</a>
        <a href="/Forca/features/">Features</a>
        <a href="/Forca/download/">Download</a>
        <a href="/Forca/docs/">Docs</a>
        <a href="/Forca/privacy/">Privacy</a>
        <a href="https://github.com/3iiik/forca" class="nav-cta" target="_blank">GitHub</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/Forca/" class="logo" style="display: inline-flex; align-items: center; gap: 10px; font-size: 18px; font-weight: 700; color: var(--text);">
            <img src="/Forca/icon.png" alt="Forca" width="20" height="20" style="border-radius: 5px;" />
            Forca
          </a>
          <p>Block distractions automatically. Forca detects meeting endings and triggers focus zones — no manual switching, no excuses, no friction.</p>
        </div>
        <div>
          <h4>Product</h4>
          <div class="footer-links">
            <a href="/Forca/features/">Features</a>
            <a href="/Forca/download/">Download</a>
            <a href="/Forca/docs/">Documentation</a>
            <a href="https://github.com/3iiik/forca/releases">Changelog</a>
          </div>
        </div>
        <div>
          <h4>Support</h4>
          <div class="footer-links">
            <a href="/Forca/docs/">Getting Started</a>
            <a href="/Forca/docs/#troubleshooting">Troubleshooting</a>
            <a href="/Forca/privacy/">Privacy Policy</a>
            <a href="https://github.com/3iiik/forca/issues">Report Bug</a>
          </div>
        </div>
        <div>
          <h4>Community</h4>
          <div class="footer-links">
            <a href="https://github.com/3iiik/forca" target="_blank">GitHub</a>
            <a href="https://github.com/3iiik/forca/discussions" target="_blank">Discussions</a>
            <a href="https://github.com/3iiik/forca/issues" target="_blank">Issues</a>
            <a href="https://github.com/3iiik/forca/blob/main/LICENSE" target="_blank">MIT License</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; {new Date().getFullYear()} 3iiik. Open source under MIT License.</span>
        <span>Made with focus &middot; Forca v1.1.0</span>
      </div>
    </footer>
  </body>
</html>

<script>
  const path = location.pathname.replace(/\/$/, '');
  document.querySelectorAll('nav .links a').forEach(a => {
    const href = a.getAttribute('href');
    if (href && !href.startsWith('http') && href !== '/Forca/' && path.startsWith(href)) {
      a.style.color = 'var(--text)';
    }
    if (href === '/Forca/' && (path === '/Forca' || path === '/Forca/')) {
      a.style.color = 'var(--text)';
    }
  });
</script>
