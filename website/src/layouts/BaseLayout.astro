      </div>
    </div>

    <main>
      <slot />
    </main>
    </div>

    <footer>
      <div class="footer-grid">
        <div class="footer-brand">
          <a href={import.meta.env.BASE_URL} class="logo" style="display: inline-flex; align-items: center;">
        <img src={import.meta.env.BASE_URL + 'branding/forca-mark.svg'} alt="Forca" width="48" height="48" />
          </a>
          <p>Block distractions automatically. Forca detects meeting endings and triggers focus zones — no manual switching, no excuses, no friction.</p>
        </div>
        <div>
          <h4>Product</h4>
          <div class="footer-links">
            <a href={import.meta.env.BASE_URL + 'features/'}>Features</a>
            <a href={import.meta.env.BASE_URL + 'download/'}>Download</a>
            <a href={import.meta.env.BASE_URL + 'docs/'}>Documentation</a>
            <a href="https://github.com/3iiik/forca/releases">Changelog</a>
          </div>
        </div>
        <div>
          <h4>Support</h4>
          <div class="footer-links">
            <a href={import.meta.env.BASE_URL + 'docs/'}>Getting Started</a>
            <a href={import.meta.env.BASE_URL + 'docs/#troubleshooting'}>Troubleshooting</a>
            <a href={import.meta.env.BASE_URL + 'privacy/'}>Privacy Policy</a>
