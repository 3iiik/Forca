          <span></span>
          <span></span>
        </button>
      </div>
      <div class="drawer-body">
        <a href={import.meta.env.BASE_URL + 'features/'}>Features</a>
        <a href={import.meta.env.BASE_URL + 'download/'}>Download</a>
        <a href={import.meta.env.BASE_URL + 'docs/'}>Docs</a>
        <a href={import.meta.env.BASE_URL + 'privacy/'}>Privacy</a>
        <hr />
        <a href="https://discord.gg/3dP5xxkPg6" target="_blank" rel="noopener noreferrer" class="drawer-icon-link">
