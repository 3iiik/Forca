            <a href="https://github.com/3iiik/forca/blob/main/LICENSE" target="_blank">MIT License</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; {new Date().getFullYear()} 3iiik. Open source under MIT License.</span>
        <span>Made with focus &middot; Forca v1.1.0</span>
      </div>
    </footer>
  </body>
</html>

<script>
  const hamburger = document.getElementById('hamburger');
  const drawer = document.getElementById('drawer');
  const overlay = document.getElementById('drawer-overlay');
  const closeBtn = document.getElementById('drawer-close');
  const drawerLinks = drawer.querySelectorAll('a');
  const body = document.body;

  function openDrawer() {
    drawer.classList.add('open');
    overlay.classList.add('open');
    hamburger.setAttribute('aria-expanded', 'true');
    body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeDrawer() {
    drawer.classList.remove('open');
    overlay.classList.remove('open');
    hamburger.setAttribute('aria-expanded', 'false');
    body.style.overflow = '';
    hamburger.focus();
  }

  hamburger.addEventListener('click', openDrawer);
  closeBtn.addEventListener('click', closeDrawer);
  overlay.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && drawer.classList.contains('open')) closeDrawer();
  });

  drawerLinks.forEach(link => link.addEventListener('click', closeDrawer));

  const path = location.pathname.replace(/\/$/, '');
  document.querySelectorAll('nav .links a, .drawer-body a:not(.drawer-icon-link)').forEach(a => {
    const href = a.getAttribute('href');
    if (href && !href.startsWith('http') && path.startsWith(href)) {
      a.style.color = 'var(--text)';
    }
  });
</script>
