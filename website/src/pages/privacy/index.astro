---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PrivacyPage } from '../../components/PrivacyPage';

const title = 'Privacy — Local-first, no data collection, fully open source';
const description = 'Forca privacy policy. No cloud account required, no data sold, local-first storage, fully open source under MIT License.';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Forca Privacy",
  "description": description,
};
---

<BaseLayout {title} {description} {structuredData}>
  <PrivacyPage client:load />
</BaseLayout>
