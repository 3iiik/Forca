---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { DownloadPage } from '../../components/DownloadPage';

const title = 'Download Forca — Windows, macOS, and Linux desktop app';
const description = 'Download Forca for Windows, macOS, or Linux. Free and open source focus app with automatic distraction blocking.';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Download Forca",
  "description": description,
};
---

<BaseLayout {title} {description} {structuredData}>
  <DownloadPage client:load />
</BaseLayout>
