---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ForcaHero } from '../components/ForcaHero';
import { ProductShowcase } from '../components/ProductShowcase';
import { WhyForca } from '../components/WhyForca';
import { ForcaFeatures } from '../components/ForcaFeatures';
import { HowItWorks } from '../components/HowItWorks';
import TailarkFAQ from '../components/TailarkFAQ';

const title = 'Forca — Automatic focus mode for deep work';
const description = 'Block distractions automatically when your focus session starts. Open source website blocker and productivity app for Windows, macOS, Linux, and Firefox.';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Forca",
  "applicationCategory": "ProductivityApplication",
  "operatingSystem": "Windows, macOS, Linux",
  "description": description,
  "url": "https://3iiik.github.io/Forca/",
  "downloadUrl": "https://3iiik.github.io/Forca/download/",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Person", "name": "3iiik" },
  "license": "https://opensource.org/licenses/MIT",
  "sameAs": "https://github.com/3iiik/forca",
}
---

<BaseLayout {title} {description} {structuredData}>
  <ForcaHero client:load />

  <ProductShowcase client:load />

  <WhyForca client:load />

  <ForcaFeatures client:load />

  <HowItWorks client:load />

  <TailarkFAQ client:load />
</BaseLayout>
