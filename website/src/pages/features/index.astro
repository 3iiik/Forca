---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { FeaturesPage } from '../../components/FeaturesPage';

const title = 'Features — Automatic focus zones, website blocking, and calendar integration';
const description = 'Explore Forca features: automatic focus activation, website blocking, multi-zone support, Firefox and Chromium browser extensions, local-first architecture.';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Forca Features",
  "description": description,
};
---

<BaseLayout {title} {description} {structuredData}>
  <FeaturesPage client:load />
</BaseLayout>
