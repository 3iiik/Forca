---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Features — Automatic focus, website blocking, and focus zones';
const description = 'Explore Forca features: automatic focus activation, website blocking, multi-zone support, Firefox and Chromium browser extensions, local-first architecture.';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Forca Features",
  "description": description,
};
---

<BaseLayout {title} {description} {structuredData}>
  <section class="page-header">
    <div class="container">
      <h1>Features</h1>
      <p>Everything Forca does to help you focus.</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container">

      <!-- Feature 1 -->
      <div class="grid-2" style="align-items: center; margin-bottom: 64px;">
        <div>
          <div class="badge badge-blue" style="margin-bottom: 12px;">Core</div>
          <h2>Automatic focus activation</h2>
          <p>Forca integrates with your calendar to detect when meetings end. When a meeting finishes, it automatically starts your configured focus zone — no buttons to press, no willpower required.</p>
          <ul>
            <li>Google Calendar integration</li>
            <li>iCal URL support</li>
            <li>Configurable post-meeting delay</li>
            <li>Manual start always available</li>
          </ul>
        </div>
        <div class="screenshot" style="aspect-ratio: 4/3;">
          <div style="text-align: center;">
            <div style="font-size: 36px;">📅 → 🎯</div>
            <div style="font-size: 13px; margin-top: 8px;">Meeting ends → Focus starts automatically</div>
          </div>
        </div>
      </div>

      <!-- Feature 2 -->
      <div class="grid-2" style="align-items: center; margin-bottom: 64px;">
        <div class="screenshot" style="aspect-ratio: 4/3; order: 2;">
          <div style="text-align: center;">
            <div style="font-size: 36px;">🚫</div>
            <div style="font-size: 13px; margin-top: 8px;">Distractions blocked during focus mode</div>
          </div>
        </div>
        <div style="order: 1;">
          <div class="badge badge-green" style="margin-bottom: 12px;">Blocking</div>
          <h2>Website blocking</h2>
          <p>Define lists of websites to block during focus sessions. The browser extension enforces these rules in real time — no configuration needed per session.</p>
          <ul>
            <li>Per-zone site lists</li>
            <li>Domain-level blocking</li>
            <li>Instant unblock on zone end</li>
            <li>Works across all supported browsers</li>
          </ul>
        </div>
      </div>

      <!-- Feature 3 -->
      <div class="grid-2" style="align-items: center; margin-bottom: 64px;">
        <div>
          <div class="badge badge-blue" style="margin-bottom: 12px;">Flexibility</div>
          <h2>Focus zones</h2>
          <p>Create multiple focus profiles for different types of work. Each zone has its own duration, blocked sites, and trigger rules. Switch between them effortlessly.</p>
          <ul>
            <li>Unlimited zones</li>
            <li>Custom durations (5–480 minutes)</li>
            <li>Per-zone blocked site lists</li>
            <li>Pause and resume support</li>
          </ul>
        </div>
        <div class="screenshot" style="aspect-ratio: 4/3;">
          <div style="text-align: center;">
            <div style="font-size: 36px;">📋</div>
            <div style="font-size: 13px; margin-top: 8px;">Deep Work · Light Focus · Reading</div>
          </div>
        </div>
      </div>

      <!-- Feature 4 -->
      <div class="grid-2" style="align-items: center; margin-bottom: 64px;">
        <div class="screenshot" style="aspect-ratio: 4/3; order: 2;">
          <div style="text-align: center;">
            <div style="font-size: 36px;">🦊 🌐</div>
            <div style="font-size: 13px; margin-top: 8px;">Firefox + All Chromium browsers</div>
          </div>
        </div>
        <div style="order: 1;">
          <div class="badge badge-yellow" style="margin-bottom: 12px;">Cross-browser</div>
          <h2>Browser support</h2>
          <p>Forca's browser extension works with Firefox (one-click install from AMO) and all major Chromium browsers including Chrome, Edge, Brave, Arc, Vivaldi, and Opera.</p>
          <ul>
            <li>Firefox: <strong>Add-ons Store</strong> (1-click)</li>
            <li>Chrome, Edge, Brave, Arc, Vivaldi, Opera: <strong>Developer Mode</strong></li>
            <li>Same blocking features across all browsers</li>
            <li>Setup guided by the desktop app</li>
          </ul>
        </div>
      </div>

      <!-- Feature 5 -->
      <div class="grid-2" style="align-items: center; margin-bottom: 48px;">
        <div>
          <div class="badge badge-green" style="margin-bottom: 12px;">Privacy</div>
          <h2>Local-first architecture</h2>
          <p>Your data never leaves your computer. Forca stores everything locally with no cloud dependency. No accounts, no tracking, no data collection.</p>
          <ul>
            <li>Zero cloud dependencies</li>
            <li>No account required</li>
            <li>Open source (MIT)</li>
            <li>Optional encrypted sync</li>
          </ul>
        </div>
        <div class="screenshot" style="aspect-ratio: 4/3;">
          <div style="text-align: center;">
            <div style="font-size: 36px;">🔒</div>
            <div style="font-size: 13px; margin-top: 8px;">Your computer → Your data</div>
          </div>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
