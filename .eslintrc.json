{
  "root": true,
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": [
    "@typescript-eslint",
    "react",
    "react-hooks"
  ],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:react/recommended",
    "plugin:react-hooks/recommended"
  ],
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "react/prop-types": "off",
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "warn"
  },
  "ignorePatterns": [
    "dist/",
    "release/",
    "node_modules/",
    "*.js",
    "*.mjs",
    "vite.config.ts"
  ],
  "overrides": [
    {
      "files": ["src/main/**/*.ts"],
      "env": {
        "browser": false,
        "node": true
      }
    },
    {
      "files": ["src/renderer/**/*.ts", "src/renderer/**/*.tsx"],
      "env": {
        "browser": true,
        "node": false
      }
    }
  ]
}
